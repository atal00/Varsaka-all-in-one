generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  supabaseId String   @unique
  email     String   @unique
  role      Role     @default(AUTHOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  articles  Article[]
}

enum Role {
  ADMIN
  EDITOR
  AUTHOR
}

model Topic {
  id               String   @id @default(cuid())
  name             String
  trendScore       Float?
  seoScore         Float?
  competitionScore Float?
  searchIntent     String?
  estimatedVolume  Int?
  difficulty       Float?
  suggestedType    String?
  suggestedAudience String?
  status           TopicStatus @default(DISCOVERED)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  articles         Article[]
  researches       Research[]
}

enum TopicStatus {
  DISCOVERED
  SELECTED
  RESEARCHING
  GENERATING
  COMPLETED
  REJECTED
}

model Research {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id])
  sources   String[] // URLs
  facts     Json     // Extracted facts, knowledge graph
  status    String   // PENDING, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Article   Article[]
}

model Article {
  id               String   @id @default(cuid())
  topicId          String?
  topic            Topic?   @relation(fields: [topicId], references: [id])
  researchId       String?
  research         Research? @relation(fields: [researchId], references: [id])
  authorId         String?
  author           User?    @relation(fields: [authorId], references: [id])
  
  title            String
  slug             String   @unique
  metaDescription  String?
  keywords         String[]
  content          String   @db.Text
  
  status           ArticleStatus @default(DRAFT)
  plagiarismScore  Float?
  factVerification String?  // JSON or text
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  publishedAt      DateTime?
}

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}
